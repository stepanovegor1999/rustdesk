			<Component Guid="4ff7f7f1-aef9-4767-89e8-2fae6d8fc51b" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-okta.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="f2bba086-99a9-4bf5-a360-2fbde8dbdd0d" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/banner.png" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="0f325c40-e49f-4c45-b5db-2877104263fd" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/banner.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="2e699153-b42a-473a-ac54-5226a751e913" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/banner_dark.png" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="effd26c2-67bf-42c1-b992-22c9006b2dd3" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/call_end.svg" KeyPath="yes" Checksum="yes" />
