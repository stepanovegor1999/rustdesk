			</Component>
			<Component Guid="c4cb92f9-03bd-43ae-a201-07e2ca2e60ac" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/about_banner_light.png" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="1ec1ab9b-3a29-4378-b69e-d431f087e067" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/actions.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="eb611b1b-3de0-4b36-8612-ca34e1178bcc" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/actions_mobile.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="7f393167-c02d-453e-a3b3-fc3b48cf4918" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/address_book.ttf" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="72a66205-b6e9-4ae2-bb93-8991b8a8d003" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/android.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="16b639bc-86da-4d25-aa97-4b74644c5859" Subdirectory="data\flutter_assets\assets">
