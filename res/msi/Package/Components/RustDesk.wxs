			</Component>
			<Component Guid="810ef2ca-0eac-4073-b2fc-94dbc34f8071" >
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/texture_rgba_renderer_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
