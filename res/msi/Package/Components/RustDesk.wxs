			</Component>
			<Component Guid="75a42db1-70d6-405c-9953-9810a5aab226" >
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/window_manager_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="3b4e04ac-ddbc-473f-a3fd-b201696f266f" >
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/window_size_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="b2f68586-1455-44a6-a8d4-dca60b21bf7f" Subdirectory="data">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/app.so" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="399fc37c-eda9-4236-841a-3a24fcfd78e8" Subdirectory="data">
