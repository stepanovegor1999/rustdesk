			</Component>
			<Component Guid="b0c3396d-269a-4a8d-a721-40262e2074de" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-google.svg" KeyPath="yes" Checksum="yes" />
