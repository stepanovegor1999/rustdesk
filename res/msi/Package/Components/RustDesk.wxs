			</Component>
			<Component Guid="0e1a1bb4-d86e-45e8-bf42-40059a9d5102" Subdirectory="data\flutter_assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/AssetManifest.bin" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="323373e9-959e-4dd3-933e-df117efb304e" Subdirectory="data\flutter_assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/AssetManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="1b8799b8-5375-4e69-9c51-95226af0f4e7" Subdirectory="data\flutter_assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/FontManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="78ca2565-04c4-4452-bd3b-debdb3c5b0a6" Subdirectory="data\flutter_assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/NOTICES.Z" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="2336a51d-dc26-4dba-b2c7-c36b238db17f" Subdirectory="data\flutter_assets\assets">
