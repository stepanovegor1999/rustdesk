			</Component>
			<Component Guid="68cc8f3e-9dfe-47d8-b80b-38ac17a408f4" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-apple.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="5c14d5b2-62fc-44eb-a88e-5b9c6fc6f43c" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/RustDesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-auth0.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="c950c918-3413-4e19-af29-184940870239" Subdirectory="data\flutter_assets\assets">
